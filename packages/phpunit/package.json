{
  "name": "@wp-tester/phpunit",
  "version": "0.1.0",
  "description": "PHPUnit test runner for WordPress projects",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:real-world": "vitest run real-world-plugins",
    "test:compatibility": "vitest run --config vitest.compatibility.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wp-tester/config": "*",
    "@wp-tester/results": "*",
    "@wp-tester/runtime": "*",
    "xml2js": "^0.6.2",
    "yauzl": "*"
  },
  "devDependencies": {
    "@types/xml2js": "^0.4.14",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
