{
  "projectType": "plugin",
  "environments": [
    {
      "name": "Latest WordPress and PHP",
      "blueprint": {
        "preferredVersions": {
          "php": "latest",
          "wp": "latest"
        }
      },
      "mounts": [
        {
          "hostPath": ".",
          "vfsPath": "/wordpress/wp-content/plugins/wp-tester-plugin/"
        }
      ]
    }
  ],
  "tests": {
    "wp": true,
    "plugin": "wp-tester-plugin",
    "phpunit": {
      "phpunitPath": "vendor/bin/phpunit",
      "configPath": "phpunit.xml.dist",
      "bootstrapPath": "tests/bootstrap.php",
      "testMode": "integration"
    }
  },
  "reporters": {
    "default": true
  }
}