{
  "projectType": "plugin",
  "environments": [
    {
      "name": "Latest WordPress and PHP",
      "php": [
        "8.1",
        "8.2"
      ],
      "mounts": [
        {
          "hostPath": ".",
          "vfsPath": "/wordpress/wp-content/plugins/wp-tester-plugin/"
        }
