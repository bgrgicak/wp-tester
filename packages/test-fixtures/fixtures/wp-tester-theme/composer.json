{
  "name": "wp-tester/test-theme",
  "description": "Minimal test theme for wp-tester",
  "type": "wordpress-theme",
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "scripts": {
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:test": "wp-env run tests-cli --env-cwd=wp-content/themes/wp-tester-test-theme vendor/bin/phpunit",
    "unit:test": "phpunit"
  }
}
