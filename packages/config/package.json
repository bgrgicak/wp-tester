{
  "name": "@wp-tester/config",
  "version": "0.0.3",
  "description": "Configuration management for wp-tester",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.js",
    "test": "vitest run",
    "update-schema": "typescript-json-schema tsconfig.json WPTesterConfig --required --skipLibCheck --out src/schema.json && node scripts/fix-schema.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@wp-playground/blueprints": "3.0.15",
    "@wp-playground/cli": "3.0.15"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "ajv": "^8.17.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.66.0",
    "vitest": "^4.0.13"
  }
}
