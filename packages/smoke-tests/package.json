{
  "name": "@wp-tester/smoke-tests",
  "version": "0.1.1",
  "description": "WordPress smoke test suite for environment validation",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@php-wasm/util": "3.0.15",
    "@wp-playground/blueprints": "3.0.15",
    "@wp-tester/results": "*",
    "@wp-tester/runtime": "*",
    "vitest": "^4.0.13"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
