{
  "name": "@wp-tester/smoke-tests",
  "version": "0.0.1",
  "description": "WordPress smoke test suite for environment validation",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@php-wasm/util": "^0.9.37",
    "@wp-playground/blueprints": "^0.9.37",
    "@wp-tester/results": "*",
    "@wp-tester/runtime": "*"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13",
    "vitest-ctrf-json-reporter": "^0.0.3"
  }
}
