{
  "name": "@wp-tester/runtime",
  "version": "0.1.6",
  "description": "WordPress Playground testing environment library",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@wp-playground/blueprints": "3.0.15",
    "@wp-playground/cli": "3.0.15",
    "@wp-tester/config": "*",
    "async-mutex": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
