{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
      "@wp-playground/cli/mounts": ["node_modules/@wp-playground/cli/mounts.d.ts"]
    }
  },
  "references": [
    { "path": "../config" },
    { "path": "../phpunit" },
    { "path": "../results" },
