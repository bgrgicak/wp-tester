{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
      "@wp-tester/config": ["../config/src/index.ts"],
      "@wp-tester/config/*": ["../config/src/*"],
      "@wp-tester/phpunit": ["../phpunit/src/index.ts"],
      "@wp-tester/phpunit/*": ["../phpunit/src/*"],
      "@wp-tester/results": ["../results/src/index.ts"],
      "@wp-tester/results/*": ["../results/src/*"],
      "@wp-tester/smoke-tests": ["../smoke-tests/src/index.ts"],
      "@wp-tester/smoke-tests/*": ["../smoke-tests/src/*"],
      "@wp-playground/cli/mounts": ["node_modules/@wp-playground/cli/mounts.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
