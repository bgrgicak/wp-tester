{
  "name": "wp-tester-monorepo",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "npm run test:types && npm run test:unit",
    "test:unit": "nx run-many --target=test --all",
    "test:types": "nx run-many --target=type-check --all",
    "cli": "tsx --tsconfig tsconfig.dev.json packages/cli/src/cli/cli.ts",
    "update-schema": "nx run @wp-tester/config:update-schema",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:serve": "docsify serve docs",
    "docs:dev": "docsify serve docs --open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgrgicak/wp-tester.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bgrgicak/wp-tester/issues"
  },
  "homepage": "https://github.com/bgrgicak/wp-tester#readme",
  "devDependencies": {
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "docsify-cli": "^4.4.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "nx": "^22.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
